{
  "name": "sonagi-design-system",
  "private": true,
  "description": "Sonagi Design System — monorepo",
  "packageManager": "pnpm@11.1.2",
  "engines": {
    "node": ">=20",
    "pnpm": ">=11"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.8.4",
    "turbo": "^2.5.4"
  },
  "lint-staged": {
    "packages/tokens/tokens/design-tokens.json": [
      "pnpm --filter @sonagi/tokens build"
    ],
    "**/*.{css,json,md}": [
      "prettier --write"
    ]
  }
}
