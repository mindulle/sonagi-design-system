{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "meta": {
    "name": "Sonagi Design System",
    "version": "1.1.0",
    "updated": "2026-06-19",
    "description": "소나기 디자인 시스템 공식 토큰. Primitive → Semantic 2-레이어 구조. 라이트/다크 모드 모두 지원."
  },

  "primitive": {
    "$description": "원시 색상값. 직접 사용 금지 — Semantic 토큰을 통해 참조할 것",

    "blue": {
      "900": { "$value": "#051520", "$type": "color" },
      "800": { "$value": "#083A64", "$type": "color" },
      "700": { "$value": "#0d5a94", "$type": "color" },
      "600": { "$value": "#1275b5", "$type": "color" },
      "500": { "$value": "#1991B9", "$type": "color" },
      "400": { "$value": "#3aadd1", "$type": "color" },
      "300": { "$value": "#6cc6e0", "$type": "color" },
      "200": { "$value": "#a8dcee", "$type": "color" },
      "100": { "$value": "#d9f0f7", "$type": "color" },
      "50": { "$value": "#eef8fb", "$type": "color" }
    },

    "neutral": {
      "950": { "$value": "#010609", "$type": "color" },
      "900": { "$value": "#0d1117", "$type": "color" },
      "850": { "$value": "#161b22", "$type": "color" },
      "800": { "$value": "#1c2128", "$type": "color" },
      "700": { "$value": "#30363d", "$type": "color" },
      "600": { "$value": "#484f58", "$type": "color" },
      "500": { "$value": "#8b949e", "$type": "color" },
      "400": { "$value": "#c9d1d9", "$type": "color" },
      "300": { "$value": "#e6eaef", "$type": "color" },
      "200": { "$value": "#f0ede8", "$type": "color" },
      "150": { "$value": "#f6f3ee", "$type": "color" },
      "100": { "$value": "#faf9f7", "$type": "color" },
      "50": { "$value": "#fff8f2", "$type": "color" }
    },

    "brand": {
      "cyan": {
        "$value": "#00ffcc",
        "$type": "color",
        "$description": "Neon Cyan — 로고/에셋 전용"
      }
    },

    "state": {
      "success": { "$value": "#2ea043", "$type": "color" },
      "warning": { "$value": "#d29922", "$type": "color" },
      "error": { "$value": "#f85149", "$type": "color" },
      "success-light": { "$value": "#d4edda", "$type": "color" },
      "warning-light": { "$value": "#fff3cd", "$type": "color" },
      "error-light": { "$value": "#fde8e8", "$type": "color" }
    }
  },

  "semantic": {
    "$description": "용도별 시맨틱 토큰. 컴포넌트에서 이 값만 참조할 것.",

    "dark": {
      "$description": "다크모드 시맨틱 매핑",
      "color": {
        "brand": {
          "primary": { "$value": "#1991B9", "$type": "color" },
          "primary-dark": { "$value": "#083A64", "$type": "color" },
          "primary-hover": { "$value": "#3aadd1", "$type": "color" },
          "logo": { "$value": "#00ffcc", "$type": "color" }
        },
        "bg": {
          "base": { "$value": "#010609", "$type": "color" },
          "surface": { "$value": "#0d1117", "$type": "color" },
          "elevated": { "$value": "#161b22", "$type": "color" },
          "overlay": { "$value": "#1c2128", "$type": "color" }
        },
        "text": {
          "primary": { "$value": "#f0f6fc", "$type": "color" },
          "secondary": { "$value": "#c9d1d9", "$type": "color" },
          "muted": { "$value": "#8b949e", "$type": "color" },
          "disabled": { "$value": "#484f58", "$type": "color" },
          "inverse": { "$value": "#010609", "$type": "color" }
        },
        "border": {
          "default": { "$value": "#30363d", "$type": "color" },
          "subtle": { "$value": "#1c2128", "$type": "color" },
          "strong": { "$value": "#1991B9", "$type": "color" }
        },
        "state": {
          "success": { "$value": "#2ea043", "$type": "color" },
          "warning": { "$value": "#d29922", "$type": "color" },
          "error": { "$value": "#f85149", "$type": "color" },
          "info": { "$value": "#1991B9", "$type": "color" }
        }
      }
    },

    "light": {
      "$description": "라이트모드 시맨틱 매핑",
      "color": {
        "brand": {
          "primary": { "$value": "#1275b5", "$type": "color" },
          "primary-dark": { "$value": "#083A64", "$type": "color" },
          "primary-hover": { "$value": "#0d5a94", "$type": "color" },
          "logo": { "$value": "#00ffcc", "$type": "color" }
        },
        "bg": {
          "base": { "$value": "#faf9f7", "$type": "color" },
          "surface": { "$value": "#fff8f2", "$type": "color" },
          "elevated": { "$value": "#ffffff", "$type": "color" },
          "overlay": { "$value": "#f0ede8", "$type": "color" }
        },
        "text": {
          "primary": { "$value": "#0d1117", "$type": "color" },
          "secondary": { "$value": "#30363d", "$type": "color" },
          "muted": { "$value": "#8b949e", "$type": "color" },
          "disabled": { "$value": "#c9d1d9", "$type": "color" },
          "inverse": { "$value": "#faf9f7", "$type": "color" }
        },
        "border": {
          "default": { "$value": "#e6eaef", "$type": "color" },
          "subtle": { "$value": "#f0ede8", "$type": "color" },
          "strong": { "$value": "#1275b5", "$type": "color" }
        },
        "state": {
          "success": { "$value": "#2ea043", "$type": "color" },
          "warning": { "$value": "#d29922", "$type": "color" },
          "error": { "$value": "#f85149", "$type": "color" },
          "info": { "$value": "#1275b5", "$type": "color" }
        }
      }
    }
  },

  "typography": {
    "fontFamily": {
      "sans": { "$value": "'Pretendard', 'Inter', system-ui, sans-serif", "$type": "fontFamily" },
      "serif": {
        "$value": "'Noto Serif KR', 'Merriweather', Georgia, serif",
        "$type": "fontFamily"
      },
      "mono": {
        "$value": "'JetBrains Mono', 'Fira Code', 'Consolas', monospace",
        "$type": "fontFamily"
      }
    },
    "fontSize": {
      "xs": { "$value": "12px", "$type": "dimension" },
      "sm": { "$value": "14px", "$type": "dimension" },
      "base": { "$value": "16px", "$type": "dimension" },
      "lg": { "$value": "18px", "$type": "dimension" },
      "xl": { "$value": "20px", "$type": "dimension" },
      "2xl": { "$value": "24px", "$type": "dimension" },
      "3xl": { "$value": "30px", "$type": "dimension" },
      "4xl": { "$value": "36px", "$type": "dimension" }
    },
    "fontWeight": {
      "regular": { "$value": "400", "$type": "fontWeight" },
      "medium": { "$value": "500", "$type": "fontWeight" },
      "semibold": { "$value": "600", "$type": "fontWeight" },
      "bold": { "$value": "700", "$type": "fontWeight" }
    },
    "lineHeight": {
      "tight": { "$value": "1.25", "$type": "number" },
      "snug": { "$value": "1.375", "$type": "number" },
      "normal": { "$value": "1.5", "$type": "number" },
      "relaxed": { "$value": "1.625", "$type": "number" },
      "loose": { "$value": "2.0", "$type": "number" }
    },
    "letterSpacing": {
      "tight": { "$value": "-0.025em", "$type": "dimension" },
      "normal": { "$value": "0em", "$type": "dimension" },
      "wide": { "$value": "0.05em", "$type": "dimension" },
      "wider": { "$value": "0.1em", "$type": "dimension" }
    }
  },

  "spacing": {
    "0": { "$value": "0px", "$type": "dimension" },
    "1": { "$value": "4px", "$type": "dimension" },
    "2": { "$value": "8px", "$type": "dimension" },
    "3": { "$value": "12px", "$type": "dimension" },
    "4": { "$value": "16px", "$type": "dimension" },
    "5": { "$value": "20px", "$type": "dimension" },
    "6": { "$value": "24px", "$type": "dimension" },
    "8": { "$value": "32px", "$type": "dimension" },
    "10": { "$value": "40px", "$type": "dimension" },
    "12": { "$value": "48px", "$type": "dimension" },
    "16": { "$value": "64px", "$type": "dimension" },
    "20": { "$value": "80px", "$type": "dimension" },
    "24": { "$value": "96px", "$type": "dimension" }
  },

  "borderRadius": {
    "none": { "$value": "0px", "$type": "dimension" },
    "sm": { "$value": "4px", "$type": "dimension" },
    "base": { "$value": "6px", "$type": "dimension" },
    "md": { "$value": "8px", "$type": "dimension" },
    "lg": { "$value": "12px", "$type": "dimension" },
    "xl": { "$value": "16px", "$type": "dimension" },
    "full": { "$value": "9999px", "$type": "dimension" }
  },

  "borderWidth": {
    "none": { "$value": "0px", "$type": "dimension" },
    "thin": { "$value": "1px", "$type": "dimension" },
    "base": { "$value": "2px", "$type": "dimension" }
  },

  "shadow": {
    "dark": {
      "sm": { "$value": "0 1px 3px rgba(1,6,9,0.4)", "$type": "shadow" },
      "md": { "$value": "0 4px 12px rgba(1,6,9,0.5)", "$type": "shadow" },
      "lg": { "$value": "0 8px 24px rgba(1,6,9,0.6)", "$type": "shadow" },
      "focus": { "$value": "0 0 0 3px rgba(25,145,185,0.4)", "$type": "shadow" }
    },
    "light": {
      "sm": { "$value": "0 1px 3px rgba(8,58,100,0.1)", "$type": "shadow" },
      "md": { "$value": "0 4px 12px rgba(8,58,100,0.12)", "$type": "shadow" },
      "lg": { "$value": "0 8px 24px rgba(8,58,100,0.15)", "$type": "shadow" },
      "focus": { "$value": "0 0 0 3px rgba(18,117,181,0.3)", "$type": "shadow" }
    }
  },

  "transition": {
    "duration": {
      "fast": { "$value": "100ms", "$type": "duration" },
      "base": { "$value": "150ms", "$type": "duration" },
      "slow": { "$value": "250ms", "$type": "duration" }
    },
    "easing": {
      "default": { "$value": "cubic-bezier(0.4, 0, 0.2, 1)", "$type": "cubicBezier" },
      "in": { "$value": "cubic-bezier(0.4, 0, 1, 1)", "$type": "cubicBezier" },
      "out": { "$value": "cubic-bezier(0, 0, 0.2, 1)", "$type": "cubicBezier" }
    }
  },

  "zIndex": {
    "base": { "$value": "0", "$type": "number" },
    "raised": { "$value": "10", "$type": "number" },
    "dropdown": { "$value": "100", "$type": "number" },
    "sticky": { "$value": "200", "$type": "number" },
    "modal": { "$value": "300", "$type": "number" },
    "toast": { "$value": "400", "$type": "number" },
    "tooltip": { "$value": "500", "$type": "number" }
  }
