{
  "name": "@sonagi/tokens",
  "version": "1.0.11",
  "description": "Sonagi Design System — CSS Custom Properties & Design Tokens",
  "license": "MIT",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./css": "./dist/variables.css",
    "./json": "./tokens/design-tokens.json"
  },
  "files": [
    "dist/",
    "tokens/"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "node scripts/build.js",
    "test": "vitest run",
    "prepack": "pnpm build"
  },
  "keywords": [
    "design-system",
    "design-tokens",
    "css-variables",
    "sonagi"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/mindulle/sonagi-design-system.git",
    "directory": "packages/tokens"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "semantic-release": "^25.0.5",
    "vitest": "^4.1.9"
  }
}
